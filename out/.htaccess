RewriteEngine On

# 1. Force HTTPS and non-www (www → non-www MUST come first)
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================================
# 2. BING 404 FIX — 301 Redirects for moved tools
# ============================================================

# Structural Category Changes
RewriteRule ^calculator/market-rates/live-silver-price/?$ /market-rates/live-silver-price/ [L,R=301]
RewriteRule ^calculator/market-rates/live-gold-price/?$ /market-rates/live-gold-price/ [L,R=301]
RewriteRule ^calculator/market-rates/exchange-rate/?$ /market-rates/exchange-rate-nepal/ [L,R=301]
RewriteRule ^market-rates/exchange-rate/?$ /market-rates/exchange-rate-nepal/ [L,R=301]
RewriteRule ^calculator/market-rates/remittance/?$ /market-rates/remittance/ [L,R=301]

RewriteRule ^calculator/math-tools/programmer/?$ /math-tools/programmer/ [L,R=301]
RewriteRule ^calculator/math-tools/statistics/?$ /math-tools/statistics/ [L,R=301]
RewriteRule ^calculator/math-tools/calculus/?$ /math-tools/calculus/ [L,R=301]
RewriteRule ^calculator/math-tools/scientific/?$ /math-tools/scientific/ [L,R=301]
RewriteRule ^calculator/math-tools/matrix/?$ /math-tools/matrix/ [L,R=301]

RewriteRule ^calculator/engineering/graphing/?$ /engineering/graphing/ [L,R=301]
RewriteRule ^calculator/engineering/3d/?$ /engineering/3d/ [L,R=301]

# Specific Tool Renames (Same content, different slug)
RewriteRule ^calculator/nepal-tax-calculator/?$ /calculator/nepal-income-tax/ [L,R=301]
RewriteRule ^calculator/age/?$ /calculator/age-calculator/ [L,R=301]
RewriteRule ^calculator/scientific/?$ /calculator/scientific-calculator/ [L,R=301]
RewriteRule ^calculator/fraction/?$ /calculator/fraction-calculator/ [L,R=301]
RewriteRule ^calculator/date-add-subtract/?$ /calculator/date-duration/ [L,R=301]
RewriteRule ^calculator/nepal-tds-calculator/?$ /calculator/nepal-tds/ [L,R=301]
RewriteRule ^calculator/nepal-neb-gpa/?$ /calculator/gpa/ [L,R=301]
RewriteRule ^calculator/gpa-to-percentage/?$ /calculator/cgpa/ [L,R=301]
RewriteRule ^calculator/engineering-gpa-calculator/?$ /calculator/engineering-gpa/ [L,R=301]
RewriteRule ^calculator/finance/?$ /finance/ [L,R=301]
RewriteRule ^calculator/category/(.*)$ /directory/ [L,R=301]
RewriteRule ^market/?$ /market-rates/ [L,R=301]
RewriteRule ^utility/?$ /directory/ [L,R=301]
RewriteRule ^calculators/?$ /directory/ [L,R=301]
RewriteRule ^calculator/formulas-lab/?$ /engineering/formulas/ [L,R=301]
RewriteRule ^calculator/swp-calculator/?$ /calculator/sip-calculator/ [L,R=301]
RewriteRule ^calculator/retirement/?$ /calculator/sip-calculator/ [L,R=301]

# Sitemap Fix
RewriteRule ^sitemap\.html$ /sitemap/ [L,R=301]

# Geometry Consolidation
RewriteRule ^math-tools/geometry/?$ /engineering/geometry/ [L,R=301]
RewriteRule ^math-tools/geometry\.html$ /engineering/geometry/ [L,R=301]
# /calculator/geometry-3d/ is a real page - no redirect needed

# Wrong top-level paths
RewriteRule ^exchange-rates/?$ /market-rates/exchange-rate-nepal/ [L,R=301]
RewriteRule ^education/?$ /math-tools/ [L,R=301]
RewriteRule ^calculator/sitemap\.html$ /sitemap/ [L,R=301]

# Old sitemap redirect
RewriteRule ^sitemap\.html$ /sitemap/ [L,R=301]

# ============================================================
# 3. Force Trailing Slash (matches Next.js trailingSlash: true)
# ============================================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteCond %{REQUEST_URI} !^/404
RewriteCond %{REQUEST_URI} !^/_next/
RewriteCond %{REQUEST_URI} !\.(js|css|json|txt|rsc|png|jpg|jpeg|gif|svg|ico|woff|woff2|webp)$ [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1/ [L,R=301]

# 4. Handle Clean URLs
DirectoryIndex index.html

# 5. Error Handling
ErrorDocument 404 /404/index.html

# 6. Browser Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpg "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

# 7. Compression (saves bandwidth)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json font/woff font/woff2
</IfModule>
